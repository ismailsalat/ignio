# Ignio environment config — copy to .env and fill in. NEVER commit your real .env.
# (.env is gitignored; .env.example is the safe template.)

# --- core bot ---
DISCORD_TOKEN=your-bot-token-here
PREFIX=!!

# --- Utilities: LLM (powers !tldr, !catchup, !translate explain) ---
# Use EITHER an OpenAI key OR an Anthropic key. Provider is auto-detected.
UTIL_LLM_API_KEY=
# Optional: force provider or model
# UTIL_LLM_PROVIDER=openai          # or: anthropic
# UTIL_LLM_MODEL=gpt-4o-mini        # openai default; anthropic default: claude-3-5-haiku

# --- Utilities: song ID (!song) — optional ---
UTIL_SONG_API_KEY=

# weather (!weather), map (!map), translate (!translate), xray (!xray)
# need NO keys — they use free providers out of the box.
