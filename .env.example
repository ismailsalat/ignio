# ============================================================
#  Ignio — environment config.  Copy to .env and fill in.
#  There is only ONE .env file. NEVER commit your real .env.
#  (.env is gitignored; this .env.example is the safe template.)
# ============================================================

# --- which environment (dev or prod) ---
IGNIO_ENV=dev

# --- bot token (use the one matching IGNIO_ENV) ---
DISCORD_TOKEN_DEV=your-dev-bot-token-here
# DISCORD_TOKEN_PROD=your-prod-bot-token-here

# --- command prefix per environment ---
COMMAND_PREFIX_DEV=!!
COMMAND_PREFIX_PROD=!

# --- owners (comma-separated user IDs), optional ---
# OWNER_IDS=123456789012345678

# ============================================================
#  Utilities providers (all OPTIONAL — commands degrade gracefully)
# ============================================================

# LLM for !tldr, !catchup, !translate explain.
# Works with an OpenAI key (sk-proj-... / sk-...) OR an Anthropic key (sk-ant-...).
# The provider is auto-detected from the key.
UTIL_LLM_API_KEY=
# Optional overrides:
# UTIL_LLM_PROVIDER=openai          # or: anthropic
# UTIL_LLM_MODEL=gpt-4o-mini        # openai default; anthropic default: claude-3-5-haiku-20241022

# Song ID for !song (AudD token). Optional.
UTIL_SONG_API_KEY=

# !weather, !map, !translate <lang>, !xray need NO keys (free providers).
